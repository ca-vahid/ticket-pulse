model AssignmentPipelineRun {
  id                Int        @id @default(autoincrement())
  ticketId          Int        @map("ticket_id")
  ticket            Ticket     @relation(fields: [ticketId], references: [id])
  workspaceId       Int        @map("workspace_id")
  workspace         Workspace  @relation(fields: [workspaceId], references: [id])
  status            String     @default("running") @db.VarChar(20) // queued | running | completed | failed | failed_schema_validation | cancelled | superseded | skipped_stale
  triggerSource     String     @db.VarChar(20) @map("trigger_source") // webhook | poll | manual | email | rebound
  reboundFrom       Json?      @map("rebound_from") // { previousTechId, previousTechName, unassignedAt, unassignedByName, reboundCount } — set when this run was triggered because the ticket bounced back from a prior assignee
  llmModel          String?    @db.VarChar(100) @map("llm_model")
  totalDurationMs   Int?       @map("total_duration_ms")
  totalTokensUsed   Int?       @map("total_tokens_used")
  recommendation    Json?      // ranked list: [{ techId, name, score, breakdown, reasoning }]
  decision          String?    @db.VarChar(20) @map("decision") // pending_review | approved | modified | rejected | auto_assigned | noise_dismissed
  decidedByEmail    String?    @db.VarChar(255) @map("decided_by_email")
  decidedAt         DateTime?  @map("decided_at")
  assignedTechId    Int?       @map("assigned_tech_id")
  assignedTech      Technician? @relation("pipelineAssignedTo", fields: [assignedTechId], references: [id])
  overrideReason    String?    @db.Text @map("override_reason")
  decisionNote      String?    @db.Text @map("decision_note")
  fullTranscript    String?    @db.Text @map("full_transcript")
  promptVersionId   Int?       @map("prompt_version_id")
  promptVersion     AssignmentPromptVersion? @relation(fields: [promptVersionId], references: [id])
  errorMessage      String?    @db.Text @map("error_message")
  queuedAt          DateTime?  @map("queued_at")
  queuedReason      String?    @db.VarChar(255) @map("queued_reason")
  claimedAt         DateTime?  @map("claimed_at")
  syncStatus        String?    @db.VarChar(20) @map("sync_status") // pending | synced | failed | dry_run | skipped
  syncedAt          DateTime?  @map("synced_at")
  syncError         String?    @db.Text @map("sync_error")
  syncPayload       Json?      @map("sync_payload")
  feedbackApplied   Boolean    @default(false) @map("feedback_applied")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  steps             AssignmentPipelineStep[]
  ticketAssignments TicketAssignment[]

  @@map("assignment_pipeline_runs")
  @@index([ticketId])
  @@index([workspaceId])
  @@index([status])
  @@index([decision])
  @@index([createdAt])
}

