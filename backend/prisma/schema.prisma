model AssignmentDailyReviewRun {
  id                     Int       @id @default(autoincrement())
  workspaceId            Int       @map("workspace_id")
  workspace              Workspace @relation(fields: [workspaceId], references: [id])
  reviewDate             DateTime  @db.Date @map("review_date")
  timezone               String    @db.VarChar(50)
  triggerSource          String    @db.VarChar(20) @map("trigger_source") // manual | scheduled | rerun
  status                 String    @default("running") @db.VarChar(30) // running | collecting | analyzing | completed | failed | cancelled
  rangeStart             DateTime? @map("range_start")
  rangeEnd               DateTime? @map("range_end")
  triggeredBy            String?   @db.VarChar(255) @map("triggered_by")
  llmModel               String?   @db.VarChar(100) @map("llm_model")
  summaryMetrics         Json?     @map("summary_metrics")
  analyzedTicketIds      Json?     @map("analyzed_ticket_ids")
  evidenceCases          Json?     @map("evidence_cases")
  promptRecommendations  Json?     @map("prompt_recommendations")
  processRecommendations Json?     @map("process_recommendations")
  skillRecommendations   Json?     @map("skill_recommendations")
  warnings               Json?     @map("warnings")
  totalDurationMs        Int?      @map("total_duration_ms")
  totalTokensUsed        Int?      @map("total_tokens_used")
  errorMessage           String?   @db.Text @map("error_message")
  fullTranscript         String?   @db.Text @map("full_transcript")
  completedAt            DateTime? @map("completed_at")
  // Optional human-readable meeting briefing (one-pager + talking points)
  // generated on-demand from the analyzed dataset for the next-day standup.
  meetingBriefing            Json?     @map("meeting_briefing")
  meetingBriefingGeneratedAt DateTime? @map("meeting_briefing_generated_at")
  meetingBriefingTokens      Int?      @map("meeting_briefing_tokens")
  meetingBriefingModel       String?   @db.VarChar(100) @map("meeting_briefing_model")
  meetingBriefingBy          String?   @db.VarChar(255) @map("meeting_briefing_by")
  // Lightweight live progress object updated throughout the run so a
  // polling client can render the same step-by-step view that SSE used to
  // provide. Persisting to the row keeps progress observable even if the
  // HTTP request that triggered the run is killed by Azure's 230s
  // load-balancer timeout — the work continues in the background and the
  // UI keeps catching up via polling.
  progress                   Json?     @map("progress")
  progressUpdatedAt          DateTime? @map("progress_updated_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  recommendations        AssignmentDailyReviewRecommendation[]

  @@map("assignment_daily_review_runs")
  @@index([workspaceId, createdAt])
  @@index([workspaceId, reviewDate])
  @@index([status])
}

