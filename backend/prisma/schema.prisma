// Ticket Pulse - FreshService Real-Time Dashboard
// Database Schema for PostgreSQL
// Multi-workspace support: all tenant-scoped tables have a workspaceId FK

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Workspace {
  id                      Int       @id @default(autoincrement())
  name                    String    @db.VarChar(100)
  slug                    String    @unique @db.VarChar(50)
  freshserviceWorkspaceId BigInt    @map("freshservice_workspace_id")
  defaultTimezone         String    @default("America/Los_Angeles") @db.VarChar(50) @map("default_timezone")
  syncIntervalMinutes     Int       @default(5) @map("sync_interval_minutes")
  categoryCustomField     String   @default("security") @db.VarChar(100) @map("category_custom_field")
  isActive                Boolean   @default(true) @map("is_active")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  technicians            Technician[]
  tickets                Ticket[]
  syncLogs               SyncLog[]
  noiseRules             NoiseRule[]
  businessHours          BusinessHour[]
  holidays               Holiday[]
  autoResponses          AutoResponse[]
  llmConfigs             LlmConfig[]
  access                 WorkspaceAccess[]
  vacationTrackerConfig  VacationTrackerConfig?
  vtLeaveTypes           VtLeaveType[]
  vtUserMappings         VtUserMapping[]
  technicianLeaves       TechnicianLeave[]
  ticketAssignments      TicketAssignment[]
  assignmentConfig       AssignmentConfig?
  competencyCategories   CompetencyCategory[]
  technicianCompetencies TechnicianCompetency[]
  assignmentPipelineRuns AssignmentPipelineRun[]
  assignmentPrompts      AssignmentPromptVersion[]
  competencyPrompts      CompetencyPromptVersion[]
  competencyRuns         CompetencyAnalysisRun[]
  calibrationRuns        CalibrationRun[]
  assignmentEpisodes     TicketAssignmentEpisode[]
  backfillRuns           BackfillRun[]

  @@map("workspaces")
}

model WorkspaceAccess {
  id          Int       @id @default(autoincrement())
  email       String    @db.VarChar(255)
  workspaceId Int       @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  role        String    @default("viewer") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([email, workspaceId])
  @@map("workspace_access")
  @@index([email])
}

model Technician {
  id              Int       @id @default(autoincrement())
  freshserviceId  BigInt    @map("freshservice_id")
  name            String    @db.VarChar(255)
  email           String?   @db.VarChar(255)
  photoUrl        String?   @db.Text @map("photo_url")
  timezone        String    @default("America/Los_Angeles") @db.VarChar(50)
  location        String?   @db.VarChar(100)
  workspaceId     Int       @map("workspace_id")
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  isActive        Boolean   @default(true) @map("is_active")
  photoSyncedAt   DateTime? @map("photo_synced_at")
  showOnMap       Boolean   @default(true) @map("show_on_map")
  isMapManager    Boolean   @default(false) @map("is_map_manager")
  workStartTime   String?   @db.VarChar(5) @map("work_start_time")
  workEndTime     String?   @db.VarChar(5) @map("work_end_time")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tickets              Ticket[]
  leaves               TechnicianLeave[]
  vtUserMappings       VtUserMapping[]
  assignmentsReceived  TicketAssignment[] @relation("assignedTo")
  competencies         TechnicianCompetency[]
  pipelineAssignments  AssignmentPipelineRun[] @relation("pipelineAssignedTo")
  competencyRuns       CompetencyAnalysisRun[]
  assignmentEpisodes   TicketAssignmentEpisode[]

  @@unique([freshserviceId, workspaceId])
  @@map("technicians")
  @@index([freshserviceId])
  @@index([workspaceId])
  @@index([email])
}

model Requester {
  id                Int       @id @default(autoincrement())
  freshserviceId    BigInt    @unique @map("freshservice_id")
  name              String    @db.VarChar(255)
  email             String?   @db.VarChar(255)
  phone             String?   @db.VarChar(50)
  mobile            String?   @db.VarChar(50)
  department        String?   @db.VarChar(255)
  jobTitle          String?   @db.VarChar(255) @map("job_title")
  timeZone          String?   @db.VarChar(100) @map("time_zone")
  language          String?   @db.VarChar(50)
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tickets           Ticket[]

  @@map("requesters")
  @@index([freshserviceId])
  @@index([email])
}

model Ticket {
  id                    Int       @id @default(autoincrement())
  freshserviceTicketId  BigInt    @unique @map("freshservice_ticket_id")
  subject               String?   @db.Text
  description           String?   @db.Text
  descriptionText       String?   @db.Text @map("description_text")
  status                String    @db.VarChar(50)
  priority              Int       @default(3)

  // Workspace
  workspaceId           Int       @map("workspace_id")
  workspace             Workspace @relation(fields: [workspaceId], references: [id])

  // Relationships
  assignedTechId        Int?      @map("assigned_tech_id")
  assignedTech          Technician? @relation(fields: [assignedTechId], references: [id])

  // Requester relationship
  requesterId           Int?      @map("requester_id") // Internal DB ID
  requester             Requester? @relation(fields: [requesterId], references: [id])
  requesterFreshserviceId BigInt? @map("requester_freshservice_id") // FreshService requester ID (for mapping)

  // Timestamps
  createdAt             DateTime  @map("created_at")
  assignedAt            DateTime? @map("assigned_at")
  resolvedAt            DateTime? @map("resolved_at")
  closedAt              DateTime? @map("closed_at")
  dueBy                 DateTime? @map("due_by")
  frDueBy               DateTime? @map("fr_due_by") // First response due by
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // Assignment tracking
  isSelfPicked          Boolean   @default(false) @map("is_self_picked")
  assignedBy            String?   @db.VarChar(255) @map("assigned_by") // Name or ID

  // Additional metadata
  source                Int?      // 1=Email, 2=Portal, 3=Phone, etc.
  category              String?   @db.VarChar(255)
  subCategory           String?   @db.VarChar(255) @map("sub_category")
  ticketCategory        String?   @db.VarChar(100) @map("ticket_category") // Custom field: security (e.g., BST, GIS, etc.)
  department            String?   @db.VarChar(255)
  isEscalated           Boolean?  @default(false) @map("is_escalated")

  // Time tracking (from FreshService stats)
  timeSpentMinutes      Int?      @map("time_spent_minutes") // Total time spent in minutes (requires time_entries API)
  billableMinutes       Int?      @map("billable_minutes")   // Billable time in minutes (requires time_entries API)
  nonBillableMinutes    Int?      @map("non_billable_minutes") // Non-billable time in minutes (requires time_entries API)
  resolutionTimeSeconds Int?      @map("resolution_time_seconds") // Time from creation to resolution (from stats field)
  firstAssignedAt       DateTime? @map("first_assigned_at") // When ticket was first assigned (from activities API)
  firstPublicAgentReplyAt DateTime? @map("first_public_agent_reply_at") // First public agent reply timestamp (from activities API)

  // Workspace filtering
  workspaceName         String?   @db.VarChar(100) @map("workspace_name")

  // CSAT (Customer Satisfaction Survey)
  csatResponseId        BigInt?   @map("csat_response_id") // FreshService CSAT response ID
  csatScore             Int?      @map("csat_score") // Acquired score (1-4)
  csatTotalScore        Int?      @map("csat_total_score") // Total possible score (usually 4)
  csatRatingText        String?   @db.VarChar(50) @map("csat_rating_text") // "Poor", "Good", "Excellent", etc.
  csatOverallRating     Int?      @map("csat_overall_rating") // FreshService rating code (e.g., 301)
  csatFeedback          String?   @db.Text @map("csat_feedback") // User's detailed feedback/comments
  csatSubmittedAt       DateTime? @map("csat_submitted_at") // When survey was submitted

  // Noise detection
  isNoise              Boolean   @default(false) @map("is_noise")
  noiseRuleMatched     String?   @db.VarChar(100) @map("noise_rule_matched")

  // Bounce / rejection tracking
  rejectionCount       Int       @default(0) @map("rejection_count")
  groupId              BigInt?   @map("group_id")

  // CSAT sync bookkeeping — when we last asked FS for this ticket's CSAT
  // response. Lets the scheduled CSAT sweep walk through the backlog
  // instead of re-checking the same 30 freshly-synced tickets every cycle.
  csatCheckedAt        DateTime? @map("csat_checked_at")

  ticketAssignments    TicketAssignment[]
  pipelineRuns         AssignmentPipelineRun[]
  assignmentEpisodes   TicketAssignmentEpisode[]

  @@map("tickets")
  @@index([workspaceId])
  @@index([assignedTechId])
  @@index([createdAt])
  @@index([status])
  @@index([workspaceName])
  @@index([requesterId])
  @@index([csatScore])
  @@index([csatSubmittedAt])
  @@index([firstPublicAgentReplyAt])
  @@index([firstAssignedAt])
  @@index([isNoise])
}

model NoiseRule {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(255)
  pattern         String    @db.Text
  description     String?   @db.Text
  category        String    @db.VarChar(100)
  isEnabled       Boolean   @default(true) @map("is_enabled")
  matchCount      Int       @default(0) @map("match_count")
  dedupWindowDays Int?      @map("dedup_window_days")
  workspaceId     Int       @map("workspace_id")
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("noise_rules")
  @@index([isEnabled])
  @@index([workspaceId])
}

model TicketActivity {
  id            Int       @id @default(autoincrement())
  ticketId      Int       @map("ticket_id")
  activityType  String    @db.VarChar(50) // assigned, status_changed, resolved, picked, self_picked, coordinator_assigned, rejected, reassigned, group_changed
  performedBy   String    @db.VarChar(255) @map("performed_by")
  performedAt   DateTime  @map("performed_at")
  details       Json?     // { fromTechId, toTechId, actorName, actorFsId, fromGroupId, toGroupId }

  @@map("ticket_activities")
  @@index([ticketId])
  @@index([performedAt])
  @@index([activityType])
}

model TicketAssignmentEpisode {
  id                  Int       @id @default(autoincrement())
  ticketId            Int       @map("ticket_id")
  ticket              Ticket    @relation(fields: [ticketId], references: [id])
  technicianId        Int       @map("technician_id")
  technician          Technician @relation(fields: [technicianId], references: [id])
  workspaceId         Int       @map("workspace_id")
  workspace           Workspace  @relation(fields: [workspaceId], references: [id])
  startedAt           DateTime  @map("started_at")
  endedAt             DateTime? @map("ended_at")
  startMethod         String    @db.VarChar(30) @map("start_method") // self_picked | coordinator_assigned | workflow_assigned | unknown
  startAssignedByName String?   @db.VarChar(255) @map("start_assigned_by_name")
  endMethod           String?   @db.VarChar(20) @map("end_method") // rejected | reassigned | closed | still_active
  endActorName        String?   @db.VarChar(255) @map("end_actor_name")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("ticket_assignment_episodes")
  @@unique([ticketId, startedAt])
  @@index([ticketId])
  @@index([technicianId])
  @@index([workspaceId])
  @@index([endMethod])
  @@index([startedAt])
}

model BackfillRun {
  id                  Int       @id @default(autoincrement())
  workspaceId         Int       @map("workspace_id")
  workspace           Workspace @relation(fields: [workspaceId], references: [id])
  status              String    @db.VarChar(20) // running | completed | failed | cancelled | interrupted
  startDate           String    @db.VarChar(10) @map("start_date")
  endDate             String    @db.VarChar(10) @map("end_date")
  skipExisting        Boolean   @default(true) @map("skip_existing")
  activityConcurrency Int       @default(3) @map("activity_concurrency")
  triggeredByEmail    String?   @db.VarChar(255) @map("triggered_by_email")

  // Live progress snapshot (updated periodically while running)
  progressPct         Int       @default(0) @map("progress_pct")
  progressStep        String?   @db.VarChar(255) @map("progress_step")
  progressPhase       String?   @db.VarChar(50) @map("progress_phase")
  ticketsTotal        Int?      @map("tickets_total")
  ticketsProcessed    Int?      @map("tickets_processed")

  // Final results
  ticketsFetched      Int?      @map("tickets_fetched")
  ticketsSynced       Int?      @map("tickets_synced")
  activitiesAnalyzed  Int?      @map("activities_analyzed")
  skippedCount        Int?      @map("skipped_count")
  elapsedMs           Int?      @map("elapsed_ms")
  errorMessage        String?   @db.Text @map("error_message")

  // Cancellation flag — backfill loop checks this and aborts
  cancelRequested     Boolean   @default(false) @map("cancel_requested")
  cancelledByEmail    String?   @db.VarChar(255) @map("cancelled_by_email")

  startedAt           DateTime  @default(now()) @map("started_at")
  completedAt         DateTime? @map("completed_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("backfill_runs")
  @@index([workspaceId, startedAt])
  @@index([status])
}

model AppSettings {
  id              Int       @id @default(autoincrement())
  key             String    @unique @db.VarChar(100)
  value           String    @db.Text
  description     String?   @db.Text
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("app_settings")
}

model SyncLog {
  id              Int       @id @default(autoincrement())
  syncType        String    @db.VarChar(50)
  status          String    @db.VarChar(20)
  recordsProcessed Int      @default(0) @map("records_processed")
  errorMessage    String?   @db.Text @map("error_message")
  workspaceId     Int       @map("workspace_id")
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  startedAt       DateTime  @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")

  @@map("sync_logs")
  @@index([startedAt])
  @@index([workspaceId])
}

model BusinessHour {
  id          Int       @id @default(autoincrement())
  dayOfWeek   Int
  startTime   String    @db.VarChar(5)
  endTime     String    @db.VarChar(5)
  isEnabled   Boolean   @default(true) @map("is_enabled")
  timezone    String    @default("America/Los_Angeles") @db.VarChar(50)
  workspaceId Int       @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("business_hours")
  @@index([dayOfWeek])
  @@index([workspaceId])
}

model Holiday {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(255)
  date        DateTime   @db.Date
  isRecurring Boolean    @default(false) @map("is_recurring")
  country     String?    @db.VarChar(2)
  isEnabled   Boolean    @default(true) @map("is_enabled")
  workspaceId Int?       @map("workspace_id")
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("holidays")
  @@index([date])
  @@index([workspaceId])
}

model AutoResponse {
  id                  Int       @id @default(autoincrement())
  ticketId            Int?      @map("ticket_id")
  freshserviceTicketId BigInt?  @map("freshservice_ticket_id")
  senderEmail         String    @db.VarChar(255) @map("sender_email")
  senderName          String?   @db.VarChar(255) @map("sender_name")

  classification      String    @db.VarChar(50)
  severity            String?   @db.VarChar(20)
  isAfterHours        Boolean   @default(false) @map("is_after_hours")
  isHoliday           Boolean   @default(false) @map("is_holiday")

  estimatedWaitMinutes Int?     @map("estimated_wait_minutes")
  queueLength         Int?      @map("queue_length")
  activeAgentCount    Int?      @map("active_agent_count")

  responseGenerated   String?   @db.Text @map("response_generated")
  responseSent        Boolean   @default(false) @map("response_sent")
  sentAt              DateTime? @map("sent_at")

  llmModel            String?   @db.VarChar(50) @map("llm_model")
  llmTokensUsed       Int?      @map("llm_tokens_used")
  configVersionUsed   Int?      @map("config_version_used")

  rawEmailBody        String?   @db.Text @map("raw_email_body")
  webhookPayload      Json?     @map("webhook_payload")
  errorMessage        String?   @db.Text @map("error_message")

  workspaceId         Int       @map("workspace_id")
  workspace           Workspace @relation(fields: [workspaceId], references: [id])

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("auto_responses")
  @@index([freshserviceTicketId])
  @@index([createdAt])
  @@index([senderEmail])
  @@index([workspaceId])
}

model LlmConfig {
  id                    Int       @id @default(autoincrement())
  version               Int       @default(1)
  status                String    @default("draft") @db.VarChar(20)

  classificationPrompt  String    @db.Text @map("classification_prompt")
  responsePrompt        String    @db.Text @map("response_prompt")

  signatureBlock        String?   @db.Text @map("signature_block")
  fallbackMessage       String?   @db.Text @map("fallback_message")
  tonePresets           Json?     @map("tone_presets")

  model                 String    @default("gpt-5.1") @db.VarChar(100)
  reasoningEffort       String    @default("none") @db.VarChar(20) @map("reasoning_effort")
  verbosity             String    @default("medium") @db.VarChar(20)
  maxOutputTokens       Int       @default(800) @map("max_output_tokens")

  baseResponseMinutes   Int       @default(30) @map("base_response_minutes")
  perTicketDelayMinutes Int       @default(10) @map("per_ticket_delay_minutes")
  afterHoursMessage     String?   @db.Text @map("after_hours_message")
  holidayMessage        String?   @db.Text @map("holiday_message")

  overrideRules         Json?     @map("override_rules")
  domainWhitelist       Json?     @map("domain_whitelist")
  domainBlacklist       Json?     @map("domain_blacklist")

  createdBy             String?   @db.VarChar(255) @map("created_by")
  publishedBy           String?   @db.VarChar(255) @map("published_by")
  publishedAt           DateTime? @map("published_at")
  notes                 String?   @db.Text

  workspaceId           Int       @map("workspace_id")
  workspace             Workspace @relation(fields: [workspaceId], references: [id])

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("llm_configs")
  @@index([status])
  @@index([version])
  @@index([workspaceId])
}

model LlmConfigHistory {
  id                Int      @id @default(autoincrement())
  configId          Int      @map("config_id")
  version           Int
  action            String   @db.VarChar(50)

  configSnapshot    Json     @map("config_snapshot")

  changedBy         String?  @db.VarChar(255) @map("changed_by")
  changeNotes       String?  @db.Text @map("change_notes")

  workspaceId       Int      @map("workspace_id")

  createdAt         DateTime @default(now()) @map("created_at")

  @@map("llm_config_history")
  @@index([configId])
  @@index([createdAt])
  @@index([workspaceId])
}

model VacationTrackerConfig {
  id          Int       @id @default(autoincrement())
  workspaceId Int       @unique @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  apiKey      String    @db.Text @map("api_key")
  syncEnabled Boolean   @default(false) @map("sync_enabled")
  lastSyncAt  DateTime? @map("last_sync_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("vacation_tracker_configs")
}

model VtLeaveType {
  id              Int       @id @default(autoincrement())
  workspaceId     Int       @map("workspace_id")
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  vtLeaveTypeId   String    @db.VarChar(255) @map("vt_leave_type_id")
  vtLeaveTypeName String    @db.VarChar(255) @map("vt_leave_type_name")
  category        String    @default("OTHER") @db.VarChar(20)
  color           String?   @db.VarChar(20)
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([workspaceId, vtLeaveTypeId])
  @@map("vt_leave_types")
  @@index([workspaceId])
}

model VtUserMapping {
  id           Int          @id @default(autoincrement())
  workspaceId  Int          @map("workspace_id")
  workspace    Workspace    @relation(fields: [workspaceId], references: [id])
  vtUserId     String       @db.VarChar(255) @map("vt_user_id")
  vtUserName   String       @db.VarChar(255) @map("vt_user_name")
  vtUserEmail  String       @db.VarChar(255) @map("vt_user_email")
  technicianId Int?         @map("technician_id")
  technician   Technician?  @relation(fields: [technicianId], references: [id])
  matchStatus  String       @default("unmatched") @db.VarChar(20) @map("match_status")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@unique([workspaceId, vtUserId])
  @@map("vt_user_mappings")
  @@index([workspaceId])
  @@index([technicianId])
}

model TechnicianLeave {
  id            Int        @id @default(autoincrement())
  workspaceId   Int        @map("workspace_id")
  workspace     Workspace  @relation(fields: [workspaceId], references: [id])
  technicianId  Int        @map("technician_id")
  technician    Technician @relation(fields: [technicianId], references: [id])
  vtLeaveId     String     @db.VarChar(255) @map("vt_leave_id")
  leaveDate     DateTime   @db.Date @map("leave_date")
  leaveTypeName String     @db.VarChar(255) @map("leave_type_name")
  category      String     @db.VarChar(20)
  status        String     @default("APPROVED") @db.VarChar(20)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@unique([vtLeaveId, leaveDate])
  @@map("technician_leaves")
  @@index([workspaceId, leaveDate])
  @@index([technicianId, leaveDate])
}

model TicketAssignment {
  id              Int                   @id @default(autoincrement())
  ticketId        Int                   @map("ticket_id")
  ticket          Ticket                @relation(fields: [ticketId], references: [id])
  assignedToId    Int                   @map("assigned_to_id")
  assignedTo      Technician            @relation("assignedTo", fields: [assignedToId], references: [id])
  assignedByEmail String                @map("assigned_by_email") @db.VarChar(255)
  workspaceId     Int                   @map("workspace_id")
  workspace       Workspace             @relation(fields: [workspaceId], references: [id])
  source          String                @default("manual") @db.VarChar(20) // manual | pipeline | auto
  pipelineRunId   Int?                  @map("pipeline_run_id")
  pipelineRun     AssignmentPipelineRun? @relation(fields: [pipelineRunId], references: [id])
  note            String?               @db.Text
  createdAt       DateTime              @default(now()) @map("created_at")

  @@map("ticket_assignments")
  @@index([ticketId])
  @@index([assignedToId])
  @@index([workspaceId, createdAt])
  @@index([pipelineRunId])
}

// ─── Ticket Assignment Pipeline ─────────────────────────────────────────────

model AssignmentConfig {
  id                      Int       @id @default(autoincrement())
  workspaceId             Int       @unique @map("workspace_id")
  workspace               Workspace @relation(fields: [workspaceId], references: [id])
  isEnabled               Boolean   @default(false) @map("is_enabled")
  autoAssign              Boolean   @default(false) @map("auto_assign")
  llmModel                String    @default("claude-sonnet-4-6-20260217") @db.VarChar(100) @map("llm_model")
  maxRecommendations      Int       @default(3) @map("max_recommendations")
  scoringWeights          Json?     @map("scoring_weights") // { competency: 0.35, workload: 0.30, location: 0.20, recency: 0.15 }
  classificationPrompt    String?   @db.Text @map("classification_prompt")
  categorizationPrompt    String?   @db.Text @map("categorization_prompt")
  recommendationPrompt    String?   @db.Text @map("recommendation_prompt")
  feedbackContext         String?   @db.Text @map("feedback_context") // accumulated knowledge from admin overrides
  pollForUnassigned       Boolean   @default(true) @map("poll_for_unassigned")
  pollMaxPerCycle         Int       @default(5) @map("poll_max_per_cycle")
  monitoredMailbox        String?   @db.VarChar(255) @map("monitored_mailbox")
  emailPollingEnabled     Boolean   @default(false) @map("email_polling_enabled")
  emailPollingIntervalSec Int       @default(60) @map("email_polling_interval_sec")
  lastEmailCheckAt        DateTime? @map("last_email_check_at")
  autoCloseNoise          Boolean   @default(false) @map("auto_close_noise")
  dryRunMode              Boolean   @default(true) @map("dry_run_mode")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@map("assignment_configs")
}

model CompetencyCategory {
  id          Int       @id @default(autoincrement())
  workspaceId Int       @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  name        String    @db.VarChar(100)
  description String?   @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  technicianCompetencies TechnicianCompetency[]

  @@unique([workspaceId, name])
  @@map("competency_categories")
  @@index([workspaceId])
}

model TechnicianCompetency {
  id                   Int                @id @default(autoincrement())
  technicianId         Int                @map("technician_id")
  technician           Technician         @relation(fields: [technicianId], references: [id])
  workspaceId          Int                @map("workspace_id")
  workspace            Workspace          @relation(fields: [workspaceId], references: [id])
  competencyCategoryId Int                @map("competency_category_id")
  competencyCategory   CompetencyCategory @relation(fields: [competencyCategoryId], references: [id], onDelete: Cascade)
  proficiencyLevel     String             @default("intermediate") @db.VarChar(20) @map("proficiency_level") // basic | intermediate | expert
  notes                String?            @db.Text
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  @@unique([technicianId, competencyCategoryId])
  @@map("technician_competencies")
  @@index([workspaceId])
  @@index([technicianId])
  @@index([competencyCategoryId])
}

model AssignmentPipelineRun {
  id                Int        @id @default(autoincrement())
  ticketId          Int        @map("ticket_id")
  ticket            Ticket     @relation(fields: [ticketId], references: [id])
  workspaceId       Int        @map("workspace_id")
  workspace         Workspace  @relation(fields: [workspaceId], references: [id])
  status            String     @default("running") @db.VarChar(20) // queued | running | completed | failed | failed_schema_validation | cancelled | superseded | skipped_stale
  triggerSource     String     @db.VarChar(20) @map("trigger_source") // webhook | poll | manual | email | rebound
  reboundFrom       Json?      @map("rebound_from") // { previousTechId, previousTechName, unassignedAt, unassignedByName, reboundCount } — set when this run was triggered because the ticket bounced back from a prior assignee
  llmModel          String?    @db.VarChar(100) @map("llm_model")
  totalDurationMs   Int?       @map("total_duration_ms")
  totalTokensUsed   Int?       @map("total_tokens_used")
  recommendation    Json?      // ranked list: [{ techId, name, score, breakdown, reasoning }]
  decision          String?    @db.VarChar(20) @map("decision") // pending_review | approved | modified | rejected | auto_assigned | noise_dismissed
  decidedByEmail    String?    @db.VarChar(255) @map("decided_by_email")
  decidedAt         DateTime?  @map("decided_at")
  assignedTechId    Int?       @map("assigned_tech_id")
  assignedTech      Technician? @relation("pipelineAssignedTo", fields: [assignedTechId], references: [id])
  overrideReason    String?    @db.Text @map("override_reason")
  decisionNote      String?    @db.Text @map("decision_note")
  fullTranscript    String?    @db.Text @map("full_transcript")
  promptVersionId   Int?       @map("prompt_version_id")
  promptVersion     AssignmentPromptVersion? @relation(fields: [promptVersionId], references: [id])
  errorMessage      String?    @db.Text @map("error_message")
  queuedAt          DateTime?  @map("queued_at")
  queuedReason      String?    @db.VarChar(255) @map("queued_reason")
  claimedAt         DateTime?  @map("claimed_at")
  syncStatus        String?    @db.VarChar(20) @map("sync_status") // pending | synced | failed | dry_run | skipped
  syncedAt          DateTime?  @map("synced_at")
  syncError         String?    @db.Text @map("sync_error")
  syncPayload       Json?      @map("sync_payload")
  feedbackApplied   Boolean    @default(false) @map("feedback_applied")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  steps             AssignmentPipelineStep[]
  ticketAssignments TicketAssignment[]

  @@map("assignment_pipeline_runs")
  @@index([ticketId])
  @@index([workspaceId])
  @@index([status])
  @@index([decision])
  @@index([createdAt])
}

model AssignmentPipelineStep {
  id              Int                  @id @default(autoincrement())
  pipelineRunId   Int                  @map("pipeline_run_id")
  pipelineRun     AssignmentPipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  stepNumber      Int                  @map("step_number")
  stepName        String               @db.VarChar(50) @map("step_name") // classification | categorization | location | availability | competency | workload | recommendation
  status          String               @default("running") @db.VarChar(20) // running | completed | failed | skipped
  durationMs      Int?                 @map("duration_ms")
  input           Json?
  output          Json?
  llmPrompt       String?              @db.Text @map("llm_prompt")
  llmResponse     String?              @db.Text @map("llm_response")
  tokensUsed      Int?                 @map("tokens_used")
  errorMessage    String?              @db.Text @map("error_message")
  createdAt       DateTime             @default(now()) @map("created_at")

  @@map("assignment_pipeline_steps")
  @@index([pipelineRunId])
  @@index([stepName])
}

model AssignmentPromptVersion {
  id              Int        @id @default(autoincrement())
  workspaceId     Int        @map("workspace_id")
  workspace       Workspace  @relation(fields: [workspaceId], references: [id])
  version         Int
  status          String     @default("draft") @db.VarChar(20) // draft | published | archived
  systemPrompt    String     @db.Text @map("system_prompt")
  toolConfig      Json?      @map("tool_config")
  createdBy       String?    @db.VarChar(255) @map("created_by")
  publishedBy     String?    @db.VarChar(255) @map("published_by")
  publishedAt     DateTime?  @map("published_at")
  notes           String?    @db.Text
  createdAt       DateTime   @default(now()) @map("created_at")

  pipelineRuns    AssignmentPipelineRun[]

  @@unique([workspaceId, version])
  @@map("assignment_prompt_versions")
  @@index([workspaceId])
  @@index([status])
}

// ─── Competency Analysis Pipeline ────────────────────────────────────────

model CompetencyPromptVersion {
  id              Int        @id @default(autoincrement())
  workspaceId     Int        @map("workspace_id")
  workspace       Workspace  @relation(fields: [workspaceId], references: [id])
  version         Int
  status          String     @default("draft") @db.VarChar(20)
  systemPrompt    String     @db.Text @map("system_prompt")
  toolConfig      Json?      @map("tool_config")
  createdBy       String?    @db.VarChar(255) @map("created_by")
  publishedBy     String?    @db.VarChar(255) @map("published_by")
  publishedAt     DateTime?  @map("published_at")
  notes           String?    @db.Text
  createdAt       DateTime   @default(now()) @map("created_at")

  competencyRuns  CompetencyAnalysisRun[]

  @@unique([workspaceId, version])
  @@map("competency_prompt_versions")
  @@index([workspaceId])
  @@index([status])
}

model CompetencyAnalysisRun {
  id                Int        @id @default(autoincrement())
  workspaceId       Int        @map("workspace_id")
  workspace         Workspace  @relation(fields: [workspaceId], references: [id])
  technicianId      Int        @map("technician_id")
  technician        Technician @relation(fields: [technicianId], references: [id])
  status            String     @default("running") @db.VarChar(20) // running | completed | failed | cancelled | rolled_back
  decision          String?    @db.VarChar(20) // auto_applied | rolled_back
  promptVersionId   Int?       @map("prompt_version_id")
  promptVersion     CompetencyPromptVersion? @relation(fields: [promptVersionId], references: [id])
  llmModel          String?    @db.VarChar(100) @map("llm_model")
  fullTranscript    String?    @db.Text @map("full_transcript")
  structuredResult  Json?      @map("structured_result")
  beforeSnapshot    Json?      @map("before_snapshot")
  afterSnapshot     Json?      @map("after_snapshot")
  errorMessage      String?    @db.Text @map("error_message")
  totalTokensUsed   Int?       @map("total_tokens_used")
  totalDurationMs   Int?       @map("total_duration_ms")
  triggeredBy       String?    @db.VarChar(255) @map("triggered_by")
  rolledBackBy      String?    @db.VarChar(255) @map("rolled_back_by")
  rolledBackAt      DateTime?  @map("rolled_back_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  steps             CompetencyAnalysisStep[]

  @@map("competency_analysis_runs")
  @@index([workspaceId])
  @@index([technicianId])
  @@index([status])
  @@index([createdAt])
}

// ─── Calibration Run Pipeline ─────────────────────────────────────────────

model CalibrationRun {
  id                    Int       @id @default(autoincrement())
  workspaceId           Int       @map("workspace_id")
  workspace             Workspace @relation(fields: [workspaceId], references: [id])
  status                String    @default("running") @db.VarChar(30) @map("status")
  periodStart           DateTime  @map("period_start")
  periodEnd             DateTime  @map("period_end")
  triggeredBy           String?   @db.VarChar(255) @map("triggered_by")

  totalRuns             Int?      @map("total_runs")
  outcome1Count         Int?      @map("outcome_1_count")
  outcome2Count         Int?      @map("outcome_2_count")
  outcome3Count         Int?      @map("outcome_3_count")
  unresolvedCount       Int?      @map("unresolved_count")
  classifiedData        Json?     @map("classified_data")

  promptFindings        Json?     @map("prompt_findings")
  promptDraftId         Int?      @map("prompt_draft_id")
  promptAnalysisTokens  Int?      @map("prompt_analysis_tokens")

  flaggedTechIds        Json?     @map("flagged_tech_ids")
  competencyRunIds      Json?     @map("competency_run_ids")
  techsProcessed        Int?      @map("techs_processed")
  techsTotal            Int?      @map("techs_total")

  totalDurationMs       Int?      @map("total_duration_ms")
  totalTokensUsed       Int?      @map("total_tokens_used")
  errorMessage          String?   @db.Text @map("error_message")
  fullTranscript        String?   @db.Text @map("full_transcript")
  llmModel              String?   @db.VarChar(100) @map("llm_model")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("calibration_runs")
  @@index([workspaceId])
  @@index([status])
  @@index([createdAt])
}

model CompetencyAnalysisStep {
  id              Int                   @id @default(autoincrement())
  runId           Int                   @map("run_id")
  run             CompetencyAnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  stepNumber      Int                   @map("step_number")
  stepName        String                @db.VarChar(50) @map("step_name")
  status          String                @default("running") @db.VarChar(20)
  durationMs      Int?                  @map("duration_ms")
  input           Json?
  output          Json?
  llmResponse     String?               @db.Text @map("llm_response")
  tokensUsed      Int?                  @map("tokens_used")
  errorMessage    String?               @db.Text @map("error_message")
  createdAt       DateTime              @default(now()) @map("created_at")

  @@map("competency_analysis_steps")
  @@index([runId])
  @@index([stepName])
}
