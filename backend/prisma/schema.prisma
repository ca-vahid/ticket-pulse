model AssignmentConfig {
  id                      Int       @id @default(autoincrement())
  workspaceId             Int       @unique @map("workspace_id")
  workspace               Workspace @relation(fields: [workspaceId], references: [id])
  isEnabled               Boolean   @default(false) @map("is_enabled")
  autoAssign              Boolean   @default(false) @map("auto_assign")
  llmModel                String    @default("claude-sonnet-4-6-20260217") @db.VarChar(100) @map("llm_model")
  maxRecommendations      Int       @default(3) @map("max_recommendations")
  scoringWeights          Json?     @map("scoring_weights") // { competency: 0.35, workload: 0.30, location: 0.20, recency: 0.15 }
  classificationPrompt    String?   @db.Text @map("classification_prompt")
  categorizationPrompt    String?   @db.Text @map("categorization_prompt")
  recommendationPrompt    String?   @db.Text @map("recommendation_prompt")
  feedbackContext         String?   @db.Text @map("feedback_context") // accumulated knowledge from admin overrides
  pollForUnassigned       Boolean   @default(true) @map("poll_for_unassigned")
  pollMaxPerCycle         Int       @default(5) @map("poll_max_per_cycle")
  monitoredMailbox        String?   @db.VarChar(255) @map("monitored_mailbox")
  emailPollingEnabled     Boolean   @default(false) @map("email_polling_enabled")
  emailPollingIntervalSec Int       @default(60) @map("email_polling_interval_sec")
  lastEmailCheckAt        DateTime? @map("last_email_check_at")
  autoCloseNoise          Boolean   @default(false) @map("auto_close_noise")
  dryRunMode              Boolean   @default(true) @map("dry_run_mode")
  dailyReviewEnabled      Boolean   @default(false) @map("daily_review_enabled")
  dailyReviewRunHour      Int       @default(18) @map("daily_review_run_hour")
  dailyReviewRunMinute    Int       @default(5) @map("daily_review_run_minute")
  dailyReviewLookbackDays Int       @default(14) @map("daily_review_lookback_days")
  // When true, the regular 5-min sync proactively pulls FreshService
  // activity + conversation data for today's ticket cohort so the daily
  // review can run with a near-warm cache. Off by default — workspaces
  // that don't use Daily Review shouldn't pay the FS API budget tax.
  dailyReviewPreheatEnabled Boolean @default(false) @map("daily_review_preheat_enabled")
  // FreshService group IDs that are excluded from auto-assignment. When a
  // ticket's group_id is in this list, the LLM still runs and produces a
  // recommendation, but decision is forced to pending_review for manual
  // approval — even when autoAssign=true. Empty array = no exclusions.
  excludedGroupIds        Int[]     @default([]) @map("excluded_group_ids")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@map("assignment_configs")
}

